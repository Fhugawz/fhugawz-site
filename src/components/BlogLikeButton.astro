---
interface Props {
	slug: string;
	initialCount?: number;
}

const { slug, initialCount = 0 } = Astro.props;
---

<div class="blog-like" data-blog-like={slug} data-initial-count={initialCount}>
	<button class="blog-like-button" type="button" aria-label="Like this article" data-i18n-aria-label="blog.like.aria">
		<span class="blog-like-heart" aria-hidden="true">♡</span>
		<span class="blog-like-count" data-blog-like-count>{initialCount}</span>
	</button>
	<span
		data-blog-like-status
		aria-live="polite"
		style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;"
	></span>
</div>

<script>
	document.querySelectorAll('[data-blog-like]').forEach((wrapper) => {
		if (!(wrapper instanceof HTMLElement)) return;

		const slug = wrapper.dataset.blogLike;
		const button = wrapper.querySelector('.blog-like-button');
		const heart = wrapper.querySelector('.blog-like-heart');
		const count = wrapper.querySelector('[data-blog-like-count]');
		const status = wrapper.querySelector('[data-blog-like-status]');
		if (!slug || !(button instanceof HTMLButtonElement) || !(heart instanceof HTMLElement) || !(count instanceof HTMLElement)) return;

		const likedKey = `fhugawz-blog-liked:${slug}`;
		const countKey = `fhugawz-blog-like-count:${slug}`;
		const initialCount = Number(wrapper.dataset.initialCount || '0');
		const startedAt = Date.now();

		const readCount = () => {
			try {
				return Number(localStorage.getItem(countKey) || initialCount);
			} catch {
				return initialCount;
			}
		};

		const readLiked = () => {
			try {
				return localStorage.getItem(likedKey) === 'true';
			} catch {
				return false;
			}
		};

		const render = (liked, nextCount) => {
			wrapper.classList.toggle('liked', liked);
			button.setAttribute('aria-pressed', liked ? 'true' : 'false');
			heart.textContent = liked ? '♥' : '♡';
			count.textContent = String(nextCount);
		};

		render(readLiked(), readCount());

		const getVisitorHash = () => {
			const visitorKey = 'fhugawz-visitor-hash';
			try {
				const existingHash = localStorage.getItem(visitorKey);
				if (existingHash) return existingHash;
				const nextHash =
					window.crypto && 'randomUUID' in window.crypto
						? window.crypto.randomUUID()
						: `${Date.now()}-${Math.random().toString(36).slice(2)}`;
				localStorage.setItem(visitorKey, nextHash);
				return nextHash;
			} catch {
				return `${Date.now()}-${Math.random().toString(36).slice(2)}`;
			}
		};

		const setStatus = (message) => {
			if (status instanceof HTMLElement) status.textContent = message;
		};

		button.addEventListener('click', async () => {
			if (readLiked()) return;
			button.disabled = true;
			button.setAttribute('aria-busy', 'true');
			setStatus('Saving like...');

			try {
				const response = await fetch('/.netlify/functions/like', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						article_slug: slug,
						visitor_hash: getVisitorHash(),
						started_at: startedAt,
					}),
				});
				const result = await response.json().catch(() => ({}));

				if (!response.ok || result.success === false) {
					setStatus(
						typeof result.message === 'string'
							? result.message
							: 'The like could not be saved right now. Please try again soon.'
					);
					return;
				}

				const nextCount = readCount() + 1;
				try {
					localStorage.setItem(likedKey, 'true');
					localStorage.setItem(countKey, String(nextCount));
				} catch {}
				render(true, nextCount);
				window.fhugawzTrackEvent?.('blog_like_click', {
					event_category: 'engagement',
					event_label: slug,
				});
				setStatus(typeof result.message === 'string' ? result.message : 'Like saved.');
			} catch {
				setStatus('The like could not be saved right now. Please try again soon.');
			} finally {
				button.disabled = false;
				button.removeAttribute('aria-busy');
			}
		});
	});
</script>
