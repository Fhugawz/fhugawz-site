---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
	keywords?: string;
	spanishTitle?: string;
	spanishDescription?: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const site = 'https://fhugawz.com';
const defaultTitle = 'Fhugawz — Cinematic Dark Pop Project';
const defaultDescription =
	'FHUGAWZ is a cinematic dark pop project and creative studio exploring memory, rupture, solitude and transformation.';
const {
	title = defaultTitle,
	description = defaultDescription,
	image = '/images/social/og-fhugawz-cinematic-dark-pop.webp',
	canonical,
	keywords,
	spanishTitle,
	spanishDescription,
	jsonLd,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();
const schema = jsonLd ? JSON.stringify(jsonLd) : null;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
// TODO: Set PUBLIC_GOOGLE_SITE_VERIFICATION after Google Search Console provides the real token.
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
{googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
{spanishTitle && <meta name="title" lang="es" content={spanishTitle} />}
{spanishDescription && <meta name="description" lang="es" content={spanishDescription} />}
<link rel="canonical" href={canonicalUrl} />
<link rel="icon" type="image/svg+xml" href="/images/brand/fhugawz-logo-favicon.svg" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="FHUGAWZ" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={title} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={title} />
{schema && <script type="application/ld+json" set:html={schema} />}
{
	gaMeasurementId && (
		<script
			is:inline
			set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
window.gtag = window.gtag || gtag;
gtag('consent', 'default', {
	analytics_storage: 'denied',
	ad_storage: 'denied',
	ad_user_data: 'denied',
	ad_personalization: 'denied'
});
window.fhugawzAnalyticsId = '${gaMeasurementId}';
window.fhugawzLoadAnalytics = function () {
	if (!window.fhugawzAnalyticsId || window.fhugawzAnalyticsLoaded) return;
	window.fhugawzAnalyticsLoaded = true;
	gtag('consent', 'update', { analytics_storage: 'granted' });
	var script = document.createElement('script');
	script.async = true;
	script.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(window.fhugawzAnalyticsId);
	document.head.appendChild(script);
	gtag('js', new Date());
	gtag('config', window.fhugawzAnalyticsId, { anonymize_ip: true });
};
window.fhugawzDenyAnalytics = function () {
	gtag('consent', 'update', { analytics_storage: 'denied' });
};
try {
	var consent = JSON.parse(localStorage.getItem('fhugawz-cookie-consent') || 'null');
	if (consent && consent.analytics === true) window.fhugawzLoadAnalytics();
	if (consent && consent.analytics === false) window.fhugawzDenyAnalytics();
} catch {}`}
		/>
	)
}
