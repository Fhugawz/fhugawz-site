---
interface Props {
	id?: string;
}

const { id = 'blog-subscribe' } = Astro.props;
const modalId = `${id}-modal`;
---

<section class="blog-subscribe-cta" aria-labelledby={`${id}-title`}>
	<p class="section-kicker" data-i18n="blog.subscribe.kicker">STAY CLOSE</p>
	<h2 id={`${id}-title`} class="blog-subscribe-title" data-i18n="blog.subscribe.title">GET THE NEXT NOTES</h2>
	<p data-i18n="blog.subscribe.description">
		Subscribe to receive new FHUGAWZ articles, production notes and project updates when they are published.
	</p>
	<button class="button primary" type="button" data-subscribe-open={modalId} data-i18n="blog.subscribe.button">
		SUBSCRIBE TO THE BLOG
	</button>
</section>

<div class="blog-subscribe-modal" id={modalId} data-subscribe-modal hidden>
	<div class="blog-subscribe-backdrop" data-subscribe-close></div>
	<div class="blog-subscribe-dialog" role="dialog" aria-modal="true" aria-labelledby={`${modalId}-title`}>
		<button class="blog-subscribe-close" type="button" data-subscribe-close aria-label="Close">×</button>
		<h2 id={`${modalId}-title`} data-i18n="blog.subscribe.modalTitle">Subscribe to the FHUGAWZ blog</h2>
		<p data-i18n="blog.subscribe.modalDescription">
			Get new articles, production notes and project updates directly in your inbox.
		</p>
		<form class="blog-subscribe-form" data-subscribe-form novalidate>
			<input type="text" name="honeypot" autocomplete="off" tabindex="-1" hidden />
			<input
				type="email"
				name="email"
				placeholder="your@email.com"
				data-i18n-placeholder="blog.subscribe.emailPlaceholder"
				aria-describedby={`${modalId}-email-error`}
				required
			/>
			<p class="field-error" id={`${modalId}-email-error`} data-subscribe-error role="alert" hidden></p>
			<button class="button primary" type="submit" data-i18n="blog.subscribe.submit">SUBSCRIBE</button>
		</form>
		<p class="blog-subscribe-note" data-i18n="blog.subscribe.note">No spam. Just project updates and useful notes.</p>
		<p class="blog-subscribe-success" data-subscribe-status data-i18n="blog.subscribe.success" hidden>
			Thanks. You are on the list.
		</p>
	</div>
</div>

<script>
	document.querySelectorAll('[data-subscribe-open]').forEach((trigger) => {
		if (!(trigger instanceof HTMLButtonElement)) return;
		const modalId = trigger.dataset.subscribeOpen;
		const modal = modalId ? document.getElementById(modalId) : null;
		if (!(modal instanceof HTMLElement)) return;

		const closeButtons = modal.querySelectorAll('[data-subscribe-close]');
		const form = modal.querySelector('[data-subscribe-form]');
		const status = modal.querySelector('[data-subscribe-status]');
		const startedAt = Date.now();
		const messages = {
			en: {
				email: 'Please enter a valid email.',
				loading: 'Subscribing...',
				fallback: 'Something went wrong. Please try again.',
			},
			es: {
				email: 'Escribe un correo valido.',
				loading: 'Suscribiendo...',
				fallback: 'Algo salio mal. Intentalo de nuevo.',
			},
		};
		const getLanguage = () => (document.documentElement.dataset.language === 'es' ? 'es' : 'en');
		const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
		const setEmailError = (message = '') => {
			const email = form instanceof HTMLFormElement ? form.querySelector('input[type="email"]') : null;
			const error = modal.querySelector('[data-subscribe-error]');
			if (!(email instanceof HTMLInputElement) || !(error instanceof HTMLElement)) return;

			email.setAttribute('aria-invalid', message ? 'true' : 'false');
			error.textContent = message;
			error.hidden = !message;
		};
		const validateForm = () => {
			const email = form instanceof HTMLFormElement ? form.querySelector('input[type="email"]') : null;
			if (!(email instanceof HTMLInputElement)) return false;
			const message = isValidEmail(email.value.trim()) ? '' : messages[getLanguage()].email;
			setEmailError(message);
			return !message;
		};

		const open = () => {
			modal.hidden = false;
			document.body.classList.add('modal-open');
			const email = modal.querySelector('input[type="email"]');
			if (email instanceof HTMLInputElement) email.focus();
		};

		const close = () => {
			modal.hidden = true;
			document.body.classList.remove('modal-open');
			trigger.focus();
		};

		trigger.addEventListener('click', open);
		closeButtons.forEach((button) => button.addEventListener('click', close));
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !modal.hidden) close();
		});

		if (form instanceof HTMLFormElement) {
			form.addEventListener('input', validateForm);
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				const email = form.querySelector('input[type="email"]');
				if (!(email instanceof HTMLInputElement) || !validateForm()) return;

				const submit = form.querySelector('button[type="submit"]');
				if (status instanceof HTMLElement) {
					status.textContent = messages[getLanguage()].loading;
					status.hidden = false;
				}
				if (submit instanceof HTMLButtonElement) {
					submit.disabled = true;
					submit.setAttribute('aria-busy', 'true');
				}

				const formData = new FormData(form);

				try {
					const response = await fetch('/.netlify/functions/subscribe', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({
							email: String(formData.get('email') || ''),
							honeypot: String(formData.get('honeypot') || ''),
							started_at: startedAt,
						}),
					});
					const result = await response.json().catch(() => ({}));
					const message =
						typeof result.message === 'string'
							? result.message
							: response.ok
								? 'Thanks. You are on the list.'
								: messages[getLanguage()].fallback;

					if (status instanceof HTMLElement) status.textContent = message;
					if (response.ok && result.success !== false) {
						window.fhugawzTrackEvent?.('subscribe_success', {
							event_category: 'lead',
							event_label: 'blog',
						});
						try {
							localStorage.setItem('fhugawz-blog-subscribe-email', email.value);
						} catch {}
						form.reset();
					}
				} catch {
					if (status instanceof HTMLElement) {
						status.textContent = messages[getLanguage()].fallback;
					}
				} finally {
					if (submit instanceof HTMLButtonElement) {
						submit.disabled = false;
						submit.removeAttribute('aria-busy');
					}
				}
			});
		}
	});
</script>
