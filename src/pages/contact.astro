---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Fhugawz — Contact for Music Production and Artist Projects"
	description="Contact FHUGAWZ for cinematic dark pop production, mixing, mastering, demo recreation and project inquiries."
	image="/images/social/og-fhugawz-production-mixing-mastering.webp"
>
	<section
		class="page-hero with-image"
		style={`--page-hero-image: url("/images/hero/fhugawz-contact-dark-pop-blog-hero.webp")`}
	>
		<div class="site-shell">
			<p class="section-kicker" data-i18n="contact.page.kicker">OPEN CHANNEL</p>
			<h1 class="page-title" data-i18n="contact.page.title">CONTACT</h1>
			<p class="lede" data-i18n="contact.page.description">
				For production, mixing, mastering, demo reconstruction or FHUGAWZ project inquiries,
				send a signal and start the conversation.
			</p>
		</div>
	</section>
	<section class="section">
		<div class="site-shell contact-panel">
			<div class="contact-copy">
				<p class="section-kicker" data-i18n="contact.panel.kicker">INQUIRIES</p>
				<h2 class="section-title" data-i18n="contact.panel.title">TELL ME ABOUT YOUR PROJECT</h2>
				<p class="section-copy" data-i18n="contact.panel.description">
					Share the idea, the song, the reference or the world you want to build. I’ll help
					you find the next step.
				</p>
			</div>
			<form class="contact-form" data-contact-form novalidate>
				<input type="text" name="honeypot" autocomplete="off" tabindex="-1" hidden />
				<div class="form-field">
					<label for="contact-name" data-i18n="contact.form.nameLabel">Name</label>
					<input
						id="contact-name"
						name="name"
						type="text"
						placeholder="Your name"
						data-i18n-placeholder="contact.form.namePlaceholder"
						aria-describedby="contact-name-error"
						required
					/>
					<p class="field-error" id="contact-name-error" data-field-error="name" role="alert" hidden></p>
				</div>
				<div class="form-field">
					<label for="contact-email" data-i18n="contact.form.emailLabel">Email</label>
					<input
						id="contact-email"
						name="email"
						type="email"
						placeholder="your@email.com"
						data-i18n-placeholder="contact.form.emailPlaceholder"
						aria-describedby="contact-email-error"
						required
					/>
					<p class="field-error" id="contact-email-error" data-field-error="email" role="alert" hidden></p>
				</div>
				<div class="form-field selected-service-field">
					<label for="contact-service" data-i18n="contact.form.selectedServiceLabel">Selected service</label>
					<select
						id="contact-service"
						name="selectedService"
						data-selected-service-field
						aria-describedby="contact-service-error"
						required
					>
						<option value="" data-i18n="contact.form.serviceDefault">Select a service</option>
						<option value="music-production" data-i18n="contact.form.serviceMusic">Music Production</option>
						<option value="mixing-mastering" data-i18n="contact.form.serviceMixing">Mixing & Mastering</option>
						<option value="demo-reconstruction" data-i18n="contact.form.serviceDemo">Demo Reconstruction</option>
						<option value="artist-world-building" data-i18n="contact.form.serviceWorld">Artist World Building</option>
					</select>
					<p class="field-error" id="contact-service-error" data-field-error="selectedService" role="alert" hidden></p>
				</div>
				<div class="form-field">
					<label for="contact-message" data-i18n="contact.form.messageLabel">Message</label>
					<textarea
						id="contact-message"
						name="message"
						placeholder="Tell me what you need, where the song is now, and where you want to take it."
						data-i18n-placeholder="contact.form.messagePlaceholder"
						aria-describedby="contact-message-error"
						required
					></textarea>
					<p class="field-error" id="contact-message-error" data-field-error="message" role="alert" hidden></p>
				</div>
				<button class="button primary contact-submit" type="submit" data-i18n="contact.form.button">SEND MESSAGE</button>
				<p class="form-status" data-contact-status data-i18n="contact.form.status" hidden>
					Message ready. Email connection will be added soon.
				</p>
			</form>
		</div>
	</section>
</Layout>

<script>
	const serviceOptions = {
		'music-production': {
			en: 'Music Production',
			es: 'Producción musical',
		},
		'mixing-mastering': {
			en: 'Mixing & Mastering',
			es: 'Mezcla y master',
		},
		'demo-reconstruction': {
			en: 'Demo Reconstruction',
			es: 'Reconstrucción de demos',
		},
		'artist-world-building': {
			en: 'Artist World Building',
			es: 'Desarrollo de universo artístico',
		},
	};

	document.querySelectorAll('[data-contact-form]').forEach((form) => {
		if (!(form instanceof HTMLFormElement)) return;

		const params = new URLSearchParams(window.location.search);
		const selectedServiceKey = params.get('service') || '';
		const selectedServiceField = form.querySelector('[data-selected-service-field]');
		const messageField = form.querySelector('#contact-message');
		const startedAt = Date.now();
		let generatedMessage = '';
		const messages = {
			en: {
				name: 'Please enter your name.',
				email: 'Please enter a valid email.',
				selectedService: 'Please choose a service.',
				message: 'Please write a short message.',
				loading: 'Sending message...',
				fallback: 'Something went wrong. Please try again.',
			},
			es: {
				name: 'Escribe tu nombre.',
				email: 'Escribe un correo valido.',
				selectedService: 'Elige un servicio.',
				message: 'Escribe un mensaje breve.',
				loading: 'Enviando mensaje...',
				fallback: 'Algo salio mal. Intentalo de nuevo.',
			},
		};
		const getLanguage = () => (document.documentElement.dataset.language === 'es' ? 'es' : 'en');
		const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
		const setFieldError = (fieldName, message = '') => {
			const field = form.elements.namedItem(fieldName);
			const error = form.querySelector(`[data-field-error="${fieldName}"]`);
			if (!(field instanceof HTMLElement) || !(error instanceof HTMLElement)) return;

			field.setAttribute('aria-invalid', message ? 'true' : 'false');
			error.textContent = message;
			error.hidden = !message;
		};
		const validateForm = () => {
			const language = getLanguage();
			const formData = new FormData(form);
			const name = String(formData.get('name') || '').trim();
			const email = String(formData.get('email') || '').trim();
			const selectedService = String(formData.get('selectedService') || '').trim();
			const message = String(formData.get('message') || '').trim();
			const errors = {
				name: name ? '' : messages[language].name,
				email: isValidEmail(email) ? '' : messages[language].email,
				selectedService: selectedService ? '' : messages[language].selectedService,
				message: message ? '' : messages[language].message,
			};

			Object.entries(errors).forEach(([fieldName, error]) => setFieldError(fieldName, error));
			return !Object.values(errors).some(Boolean);
		};

		const applySelectedService = () => {
			if (
				!(selectedServiceField instanceof HTMLSelectElement) ||
				!(messageField instanceof HTMLTextAreaElement)
			) {
				return;
			}

			const currentServiceKey = selectedServiceField.value;
			const selectedService = serviceOptions[currentServiceKey];
			if (!selectedService) return;

			const language = document.documentElement.dataset.language === 'es' ? 'es' : 'en';
			const serviceName = selectedService[language];
			const nextMessage =
				language === 'es'
					? `Estoy interesado en ${serviceName}. Esto es lo que necesito:`
					: `I'm interested in ${serviceName}. Here is what I need:`;

			if (!messageField.value || messageField.value === generatedMessage) {
				messageField.value = nextMessage;
				generatedMessage = nextMessage;
			}
		};

		if (selectedServiceKey in serviceOptions && selectedServiceField instanceof HTMLSelectElement) {
			selectedServiceField.value = selectedServiceKey;
		}

		applySelectedService();
		if (selectedServiceField instanceof HTMLSelectElement) {
			selectedServiceField.addEventListener('change', applySelectedService);
		}
		window.addEventListener('fhugawz:languagechange', applySelectedService);
		form.querySelectorAll('input, select, textarea').forEach((field) => {
			field.addEventListener('input', () => validateForm());
			field.addEventListener('change', () => validateForm());
		});

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			const status = form.querySelector('[data-contact-status]');
			const submit = form.querySelector('.contact-submit');

			if (!validateForm()) return;

			if (status instanceof HTMLElement) {
				status.textContent = messages[getLanguage()].loading;
				status.hidden = false;
			}
			if (submit instanceof HTMLButtonElement) {
				submit.disabled = true;
				submit.setAttribute('aria-busy', 'true');
			}

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || ''),
				email: String(formData.get('email') || ''),
				selected_service: String(formData.get('selectedService') || ''),
				message: String(formData.get('message') || ''),
				honeypot: String(formData.get('honeypot') || ''),
				started_at: startedAt,
			};

			try {
				const response = await fetch('/.netlify/functions/contact', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify(payload),
				});
				const result = await response.json().catch(() => ({}));
				const message =
					typeof result.message === 'string'
						? result.message
							: response.ok
								? 'Message sent. Thank you for reaching out.'
								: messages[getLanguage()].fallback;

				if (status instanceof HTMLElement) status.textContent = message;
				if (response.ok && result.success !== false) form.reset();
			} catch {
				if (status instanceof HTMLElement) {
					status.textContent = messages[getLanguage()].fallback;
				}
			} finally {
				if (submit instanceof HTMLButtonElement) {
					submit.disabled = false;
					submit.removeAttribute('aria-busy');
				}
			}
		});
	});
</script>
