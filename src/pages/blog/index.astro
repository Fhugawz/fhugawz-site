---

<Layout
	title="Fhugawz — Dark Pop Production Diary"
	description="Production notes, artist reflections and creative field notes from FHUGAWZ, covering music, tools, dark pop, reconstruction and independent world building."
	image="/images/social/og-fhugawz-cinematic-dark-pop.webp"
>
	<section
		class="page-hero with-image"
		style={`--page-hero-image: url("/images/hero/fhugawz-production-diary-dark-pop-blog-hero.webp")`}
	>
		<div class="site-shell">
			<p class="section-kicker" data-i18n="blog.page.kicker">FIELD NOTES</p>
			<h1 class="page-title" data-i18n="blog.page.title">BLOG</h1>
			<p class="lede" data-i18n="blog.page.description">
				Notes on music, production, tools and the process of building an independent artistic
				world in public, step by step, from the inside.
			</p>
		</div>
	</section>
	<section class="section">
		<div class="site-shell">
			<div class="blog-filter" aria-label="Blog category filters">
				<button class="blog-filter-button active" type="button" data-blog-filter="all" data-i18n="blog.filter.all">ALL</button>
				<button class="blog-filter-button" type="button" data-blog-filter="project-diary" data-i18n="blog.filter.projectDiary">PROJECT DIARY</button>
				<button class="blog-filter-button" type="button" data-blog-filter="production-notes" data-i18n="blog.filter.productionNotes">PRODUCTION NOTES</button>
			</div>
			<div class="card-grid two">
				{posts.map((post) => <BlogCard {...post} />)}
			</div>
		</div>
	</section>
</Layout>

<script>
	const filterButtons = document.querySelectorAll('[data-blog-filter]');
	const blogCards = document.querySelectorAll('[data-blog-card]');

	filterButtons.forEach((button) => {
		if (!(button instanceof HTMLButtonElement)) return;

		button.addEventListener('click', () => {
			const filter = button.dataset.blogFilter || 'all';
			filterButtons.forEach((item) => item.classList.toggle('active', item === button));
			blogCards.forEach((card) => {
				if (!(card instanceof HTMLElement)) return;
				const shouldShow = filter === 'all' || card.dataset.blogCategory === filter;
				card.hidden = !shouldShow;
			});
		});
	});
</script>
