					'legal.terms.title': 'TÉRMINOS DE SERVICIO',
					'legal.terms.lede':
						'Condiciones básicas para usar el sitio y solicitar servicios de FHUGAWZ Studio.',
					'legal.cookies.kicker': 'LEGAL',
					'legal.cookies.title': 'POLÍTICA DE COOKIES',
					'legal.cookies.lede':
						'Información sobre cookies, almacenamiento local y seguimiento básico del sitio.',
					'legal.copyright.kicker': 'LEGAL',
					'legal.copyright.title': 'AVISO DE COPYRIGHT',
					'legal.copyright.lede':
						'Propiedad y reglas de uso para música, visuales, escritura y diseño de Fhugawz.',
				},
			};

			const escapeFhugawzHtml = (value) =>
				value.replace(/[&<>"']/g, (character) => {
					const entities = {
						'&': '&amp;',
						'<': '&lt;',
						'>': '&gt;',
						'"': '&quot;',
						"'": '&#39;',
					};

					return entities[character];
				});

			const applyFhugawzLanguage = (language) => {
				const nextLanguage = language === 'es' ? 'es' : 'en';

				document.documentElement.lang = nextLanguage;
				document.documentElement.dataset.language = nextLanguage;
				document.querySelectorAll('[data-i18n]').forEach((element) => {
					const key = element.getAttribute('data-i18n');
					if (!key) return;

					if (!element.dataset.i18nDefault) {
						element.dataset.i18nDefault = element.textContent || '';
					}

					const translatedText =
						nextLanguage === 'en'
							? element.dataset.i18nDefault
							: fhugawzTranslations.es[key] || element.dataset.i18nDefault;

					if (element.hasAttribute('data-i18n-linebreaks')) {
						if (!element.dataset.i18nDefaultHtml) {
							element.dataset.i18nDefaultHtml = element.innerHTML;
						}

						element.innerHTML =
							nextLanguage === 'en'
								? element.dataset.i18nDefaultHtml
								: translatedText.split('\n').map(escapeFhugawzHtml).join('<br>');
						return;
					}

					if (element.hasAttribute('data-i18n-mobile-linebreaks')) {
						if (!element.dataset.i18nDefaultHtml) {
							element.dataset.i18nDefaultHtml = element.innerHTML;
						}

						element.innerHTML =
							nextLanguage === 'en'
								? element.dataset.i18nDefaultHtml
								: translatedText
										.split('\n')
										.map((line) => `<span class="mobile-i18n-line">${escapeFhugawzHtml(line)}</span>`)
										.join('<span class="desktop-i18n-space"> </span><br class="mobile-i18n-break">');
						return;
					}

					element.textContent = translatedText;
				});

				document.querySelectorAll('[data-i18n-placeholder]').forEach((element) => {
					const key = element.getAttribute('data-i18n-placeholder');
					if (!key || !(element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement)) return;

					if (!element.dataset.i18nDefaultPlaceholder) {
						element.dataset.i18nDefaultPlaceholder = element.placeholder || '';
					}

					element.placeholder =
						nextLanguage === 'en'
							? element.dataset.i18nDefaultPlaceholder
							: fhugawzTranslations.es[key] || element.dataset.i18nDefaultPlaceholder;
				});

				document.querySelectorAll('[data-i18n-alt]').forEach((element) => {
					const key = element.getAttribute('data-i18n-alt');
					if (!key || !(element instanceof HTMLImageElement)) return;

					if (!element.dataset.i18nDefaultAlt) {
						element.dataset.i18nDefaultAlt = element.alt || '';
					}

					element.alt =
						nextLanguage === 'en'
							? element.dataset.i18nDefaultAlt
							: fhugawzTranslations.es[key] || element.dataset.i18nDefaultAlt;
				});

				document.querySelectorAll('[data-i18n-tooltip]').forEach((element) => {
					const key = element.getAttribute('data-i18n-tooltip');
					if (!key) return;

					if (!element.dataset.i18nDefaultTooltip) {
						element.dataset.i18nDefaultTooltip = element.dataset.tooltip || '';
					}

					element.dataset.tooltip =
						nextLanguage === 'en'
							? element.dataset.i18nDefaultTooltip
							: fhugawzTranslations.es[key] || element.dataset.i18nDefaultTooltip;
				});

				document.querySelectorAll('[data-i18n-aria-label]').forEach((element) => {
					const key = element.getAttribute('data-i18n-aria-label');
					if (!key) return;

					if (!element.dataset.i18nDefaultAriaLabel) {
						element.dataset.i18nDefaultAriaLabel = element.getAttribute('aria-label') || '';
					}

					element.setAttribute(
						'aria-label',
						nextLanguage === 'en'
							? element.dataset.i18nDefaultAriaLabel
							: fhugawzTranslations.es[key] || element.dataset.i18nDefaultAriaLabel
					);
				});

				document.querySelectorAll('[data-language-toggle]').forEach((button) => {
					const isSpanish = nextLanguage === 'es';
					const label = button.querySelector('[data-language-toggle-label]');
					button.setAttribute('data-active-lang', nextLanguage);
					button.setAttribute('aria-pressed', isSpanish ? 'true' : 'false');
					button.setAttribute(
						'aria-label',
						isSpanish ? 'Cambiar idioma a inglés' : 'Switch language to Spanish'
					);
					if (label) label.textContent = isSpanish ? 'ES' : 'EN';
				});

				try {
					localStorage.setItem('fhugawz-language', nextLanguage);
				} catch {}

				window.dispatchEvent(new CustomEvent('fhugawz:languagechange', { detail: { language: nextLanguage } }));
			};

			const initializeFhugawzLanguage = () => {
				let storedLanguage = 'en';
				try {
					storedLanguage = localStorage.getItem('fhugawz-language') || 'en';
				} catch {}

				applyFhugawzLanguage(storedLanguage);

				document.querySelectorAll('[data-language-toggle]').forEach((button) => {
					button.addEventListener('click', () => {
						const currentLanguage = button.getAttribute('data-active-lang') === 'es' ? 'es' : 'en';
						applyFhugawzLanguage(currentLanguage === 'es' ? 'en' : 'es');
					});
				});
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initializeFhugawzLanguage, { once: true });
			} else {
				initializeFhugawzLanguage();
			}
		</script>
	</body>
</html>
